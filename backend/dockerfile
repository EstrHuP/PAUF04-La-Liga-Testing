# -------------------------------
# Dockerfile para Laravel en Render
# -------------------------------

FROM php:8.5-fpm

# Render: env vars should configure the app; log to stderr by default.
ENV LOG_CHANNEL=stderr

# 1️ Instala dependencias del sistema necesarias para Laravel y SQLite
RUN apt-get update && apt-get install -y \
    git unzip curl libzip-dev libonig-dev libpng-dev libxml2-dev zip sqlite3 libsqlite3-dev build-essential \
    && docker-php-ext-configure zip \
    && docker-php-ext-install pdo mbstring zip bcmath pdo_sqlite \
    && rm -rf /var/lib/apt/lists/*

# 2️ Copia Composer desde la imagen oficial
COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

# 3️ Directorio de trabajo
WORKDIR /var/www/html

# 4️ Copia Composer manifests e instala dependencias
COPY composer.json composer.lock ./
RUN composer install --no-dev --optimize-autoloader --no-interaction --no-scripts

# 5️ Copia el resto del proyecto al contenedor
COPY . .

# 6️ Crear archivo SQLite si no existe y dar permisos
RUN mkdir -p database storage bootstrap/cache \
    && touch database/database.sqlite \
    && chown -R www-data:www-data database storage bootstrap/cache \
    && mkdir -p storage/framework/cache storage/framework/sessions storage/framework/views \
    && chmod -R a+rwX database storage bootstrap/cache

# 7️ Expone el puerto que Laravel usará
EXPOSE 10000

# 8️ Comando para iniciar Laravel
CMD ["sh", "-c", "set -e; if [ -z \"${APP_KEY:-}\" ]; then echo \"Missing APP_KEY (set it in Render Environment)\"; exit 1; fi; mkdir -p storage/framework/cache storage/framework/sessions storage/framework/views bootstrap/cache database; touch database/database.sqlite; chmod -R a+rwX storage bootstrap/cache database; if [ \"${DB_CONNECTION:-}\" = \"sqlite\" ] && [ -z \"${DB_DATABASE:-}\" ]; then export DB_DATABASE=/var/www/html/database/database.sqlite; fi; php artisan migrate --force --no-interaction; php artisan serve --host=0.0.0.0 --port=${PORT:-10000}"]
